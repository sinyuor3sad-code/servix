# ══════════════════════════════════════════════
# SERVIX — Production Environment Variables
# ══════════════════════════════════════════════
# Copy this file to .env and fill in all values
# DO NOT commit the .env file to version control!

# ── PostgreSQL ──
POSTGRES_USER=servix
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here
POSTGRES_DB=servix_platform
POSTGRES_PORT=5432

# ── Redis ──
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_redis_password

# ── MinIO (Object Storage / Backups) ──
MINIO_ROOT_USER=servix_minio
MINIO_ROOT_PASSWORD=CHANGE_ME_minio_password

# ── JWT Authentication ──
JWT_ACCESS_SECRET=CHANGE_ME_jwt_access_secret_min_32_chars
JWT_REFRESH_SECRET=CHANGE_ME_jwt_refresh_secret_min_32_chars

# ── Encryption ──
ENCRYPTION_KEY=CHANGE_ME_32_byte_hex_key

# ── Backup ──
BACKUP_ENCRYPTION_PASSPHRASE=CHANGE_ME_backup_passphrase

# ── CORS (comma-separated origins) ──
CORS_ORIGINS=https://app.servi-x.com,https://booking.servi-x.com,https://admin.servi-x.com,https://servi-x.com

# ── Public URLs ──
API_URL=https://api.servi-x.com/api/v1
WS_URL=https://api.servi-x.com
NEXT_PUBLIC_BOOKING_URL=https://booking.servi-x.com
NEXT_PUBLIC_DASHBOARD_URL=https://app.servi-x.com

# ── Sentry (Error Tracking — optional) ──
SENTRY_DSN=

# ── Google Gemini AI (optional) ──
GEMINI_API_KEY=

# ── Cloudflare AI (optional) ──
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_AI_TOKEN=

# ── WhatsApp Business API (optional) ──
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_REGISTRATION_PIN=
META_APP_ID=
META_APP_SECRET=

# ── Grafana ──
GRAFANA_PASSWORD=CHANGE_ME_grafana_password

# ── Vault (optional — for secrets management) ──
VAULT_TOKEN=

# ── Replication (optional — for read replica) ──
REPLICATION_PASSWORD=

# ── Off-site Backup (optional — S3-compatible) ──
OFFSITE_S3_ENDPOINT=
OFFSITE_S3_BUCKET=
OFFSITE_S3_ACCESS_KEY=
OFFSITE_S3_SECRET_KEY=
OFFSITE_S3_REGION=us-east-1

# ── Alerting (optional) ──
ALERT_SLACK_WEBHOOK_URL=
ALERT_EMAIL_TO=
ALERT_EMAIL_FROM=
ALERT_SMTP_HOST=
ALERT_SMTP_USER=
ALERT_SMTP_PASS=
