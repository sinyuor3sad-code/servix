{
  "id": null,
  "uid": "servix-overview",
  "title": "SERVIX — System Overview",
  "tags": ["servix", "production"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 100,
      "title": "🟢 API & Application",
      "type": "row",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 }
    },
    {
      "id": 1,
      "title": "HTTP Request Rate",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 1, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total[5m])) by (method, status_code)",
          "legendFormat": "{{method}} — {{status_code}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 2,
      "title": "HTTP Latency (p95 / p50)",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 1, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 3,
      "title": "Error Rate (5xx)",
      "type": "stat",
      "gridPos": { "x": 16, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{status_code=~\"5..\"}[5m])) / sum(rate(http_requests_total[5m])) * 100",
          "legendFormat": "Error %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": { "steps": [
            { "color": "green", "value": 0 },
            { "color": "yellow", "value": 1 },
            { "color": "red", "value": 5 }
          ]},
          "unit": "percent",
          "noValue": "0%"
        }
      }
    },
    {
      "id": 4,
      "title": "Active Tenants",
      "type": "stat",
      "gridPos": { "x": 20, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "servix_cached_tenants_total",
          "legendFormat": "Tenants"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "noValue": "0",
          "thresholds": { "steps": [{ "color": "blue", "value": 0 }] }
        }
      }
    },
    {
      "id": 5,
      "title": "Event Loop Lag",
      "type": "stat",
      "gridPos": { "x": 16, "y": 5, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "nodejs_eventloop_lag_seconds * 1000",
          "legendFormat": "Lag (ms)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "noValue": "N/A",
          "thresholds": { "steps": [
            { "color": "green", "value": 0 },
            { "color": "yellow", "value": 50 },
            { "color": "red", "value": 200 }
          ]}
        }
      }
    },
    {
      "id": 6,
      "title": "Process Uptime",
      "type": "stat",
      "gridPos": { "x": 20, "y": 5, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "process_start_time_seconds{job=\"servix-api\"}",
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "dtdurations",
          "noValue": "N/A"
        }
      }
    },
    {
      "id": 200,
      "title": "🖥️ Node.js Runtime",
      "type": "row",
      "gridPos": { "x": 0, "y": 9, "w": 24, "h": 1 }
    },
    {
      "id": 7,
      "title": "Node.js Memory Usage",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 10, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "process_resident_memory_bytes{job=\"servix-api\"} / 1024 / 1024",
          "legendFormat": "RSS (MB) — {{instance}}"
        },
        {
          "expr": "nodejs_heap_size_used_bytes{job=\"servix-api\"} / 1024 / 1024",
          "legendFormat": "Heap Used (MB) — {{instance}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "decmbytes" } }
    },
    {
      "id": 8,
      "title": "BullMQ Queue Depth",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 10, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        { "expr": "servix_bullmq_waiting_total", "legendFormat": "Waiting" },
        { "expr": "servix_bullmq_active_total", "legendFormat": "Active" },
        { "expr": "servix_bullmq_failed_total", "legendFormat": "Failed" }
      ]
    },
    {
      "id": 9,
      "title": "Cache Hit Ratio",
      "type": "gauge",
      "gridPos": { "x": 16, "y": 10, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "servix_cache_hits_total / (servix_cache_hits_total + servix_cache_misses_total) * 100",
          "legendFormat": "Hit %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0, "max": 100, "unit": "percent", "noValue": "N/A",
          "thresholds": { "steps": [
            { "color": "red", "value": 0 },
            { "color": "yellow", "value": 70 },
            { "color": "green", "value": 90 }
          ]}
        }
      }
    },
    {
      "id": 300,
      "title": "🗄️ PostgreSQL",
      "type": "row",
      "gridPos": { "x": 0, "y": 18, "w": 24, "h": 1 }
    },
    {
      "id": 10,
      "title": "PostgreSQL Active Connections",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 19, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "pg_stat_activity_count",
          "legendFormat": "{{state}}"
        }
      ]
    },
    {
      "id": 11,
      "title": "Database Size (MB)",
      "type": "stat",
      "gridPos": { "x": 8, "y": 19, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "pg_database_size_bytes{datname=\"servix_platform\"} / 1024 / 1024",
          "legendFormat": "Size (MB)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "decmbytes", "noValue": "N/A",
          "thresholds": { "steps": [
            { "color": "green", "value": 0 },
            { "color": "yellow", "value": 500 },
            { "color": "red", "value": 2000 }
          ]}
        }
      }
    },
    {
      "id": 12,
      "title": "DB Query Duration (p95)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 19, "w": 6, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(servix_db_query_duration_seconds_bucket[5m]))",
          "legendFormat": "p95 Query Time"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 13,
      "title": "Transactions / sec",
      "type": "timeseries",
      "gridPos": { "x": 18, "y": 19, "w": 6, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "rate(pg_stat_database_xact_commit{datname=\"servix_platform\"}[5m])",
          "legendFormat": "Commits/s"
        },
        {
          "expr": "rate(pg_stat_database_xact_rollback{datname=\"servix_platform\"}[5m])",
          "legendFormat": "Rollbacks/s"
        }
      ]
    },
    {
      "id": 14,
      "title": "DB Deadlocks",
      "type": "stat",
      "gridPos": { "x": 8, "y": 23, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "increase(pg_stat_database_deadlocks{datname=\"servix_platform\"}[1h])",
          "legendFormat": "Last Hour"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "noValue": "0",
          "thresholds": { "steps": [
            { "color": "green", "value": 0 },
            { "color": "red", "value": 1 }
          ]}
        }
      }
    },
    {
      "id": 400,
      "title": "🖧 Server Infrastructure",
      "type": "row",
      "gridPos": { "x": 0, "y": 27, "w": 24, "h": 1 }
    },
    {
      "id": 15,
      "title": "CPU Usage (%)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 28, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
          "legendFormat": "CPU Usage %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "min": 0, "max": 100,
          "thresholds": { "steps": [
            { "color": "green", "value": 0 },
            { "color": "yellow", "value": 70 },
            { "color": "red", "value": 90 }
          ]}
        }
      }
    },
    {
      "id": 16,
      "title": "Memory Usage",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 28, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "(node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes) / 1024 / 1024 / 1024",
          "legendFormat": "Used (GB)"
        },
        {
          "expr": "node_memory_MemTotal_bytes / 1024 / 1024 / 1024",
          "legendFormat": "Total (GB)"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "decgbytes" } }
    },
    {
      "id": 17,
      "title": "Disk Usage",
      "type": "gauge",
      "gridPos": { "x": 16, "y": 28, "w": 4, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "100 - ((node_filesystem_avail_bytes{mountpoint=\"/\",fstype!=\"rootfs\"} / node_filesystem_size_bytes{mountpoint=\"/\",fstype!=\"rootfs\"}) * 100)",
          "legendFormat": "Disk Used %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0, "max": 100, "unit": "percent",
          "thresholds": { "steps": [
            { "color": "green", "value": 0 },
            { "color": "yellow", "value": 70 },
            { "color": "red", "value": 85 }
          ]}
        }
      }
    },
    {
      "id": 18,
      "title": "Network Traffic",
      "type": "timeseries",
      "gridPos": { "x": 20, "y": 28, "w": 4, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "rate(node_network_receive_bytes_total{device=\"eth0\"}[5m]) / 1024",
          "legendFormat": "RX (KB/s)"
        },
        {
          "expr": "rate(node_network_transmit_bytes_total{device=\"eth0\"}[5m]) / 1024",
          "legendFormat": "TX (KB/s)"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "KBs" } }
    }
  ]
}
