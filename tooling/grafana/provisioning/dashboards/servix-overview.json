{
  "id": null,
  "uid": "servix-overview",
  "title": "SERVIX — Production Overview",
  "tags": ["servix", "production"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": { "list": [] },
  "panels": [
    { "id": 100, "title": "API & Application", "type": "row", "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 } },
    {
      "id": 1, "title": "HTTP Request Rate", "type": "timeseries",
      "gridPos": { "x": 0, "y": 1, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(rate(http_requests_total[5m])) by (method, status_code)", "legendFormat": "{{method}} {{status_code}}" }],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "fillOpacity": 10 } } }
    },
    {
      "id": 2, "title": "HTTP Latency (p95 / p50)", "type": "timeseries",
      "gridPos": { "x": 8, "y": 1, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p50" }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "fillOpacity": 10 } } }
    },
    {
      "id": 3, "title": "Error Rate (5xx)", "type": "timeseries",
      "gridPos": { "x": 16, "y": 1, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(rate(http_requests_total{status_code=~\"5..\"}[5m])) / sum(rate(http_requests_total[5m])) * 100", "legendFormat": "5xx %" }],
      "fieldConfig": { "defaults": { "unit": "percent", "custom": { "fillOpacity": 20 }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.5 }, { "color": "red", "value": 1 }] } } }
    },
    {
      "id": 4, "title": "API Instances Up", "type": "stat",
      "gridPos": { "x": 0, "y": 9, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "count(up{job=\"servix-api\"} == 1)" }],
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 1 }, { "color": "green", "value": 2 }] } } }
    },
    {
      "id": 5, "title": "Total Requests (24h)", "type": "stat",
      "gridPos": { "x": 4, "y": 9, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(increase(http_requests_total[24h]))" }],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 6, "title": "DB Query p95", "type": "stat",
      "gridPos": { "x": 8, "y": 9, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "histogram_quantile(0.95, sum(rate(servix_db_query_duration_seconds_bucket[5m])) by (le))" }],
      "fieldConfig": { "defaults": { "unit": "s", "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.1 }, { "color": "red", "value": 0.5 }] } } }
    },
    {
      "id": 7, "title": "Cache Hit Rate", "type": "gauge",
      "gridPos": { "x": 12, "y": 9, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(rate(servix_cache_hits_total[5m])) / (sum(rate(servix_cache_hits_total[5m])) + sum(rate(servix_cache_misses_total[5m]))) * 100" }],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 50 }, { "color": "green", "value": 80 }] } } }
    },
    {
      "id": 8, "title": "BullMQ Jobs", "type": "stat",
      "gridPos": { "x": 16, "y": 9, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "servix_bullmq_waiting_total", "legendFormat": "Waiting" },
        { "expr": "servix_bullmq_active_total", "legendFormat": "Active" },
        { "expr": "servix_bullmq_failed_total", "legendFormat": "Failed" }
      ]
    },
    {
      "id": 9, "title": "Event Loop Lag", "type": "stat",
      "gridPos": { "x": 20, "y": 9, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "nodejs_eventloop_lag_seconds * 1000" }],
      "fieldConfig": { "defaults": { "unit": "ms", "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 50 }, { "color": "red", "value": 200 }] } } }
    },

    { "id": 200, "title": "Server Infrastructure", "type": "row", "gridPos": { "x": 0, "y": 13, "w": 24, "h": 1 } },
    {
      "id": 10, "title": "CPU Usage", "type": "timeseries",
      "gridPos": { "x": 0, "y": 14, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)", "legendFormat": "CPU %" }],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "custom": { "fillOpacity": 15 }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 70 }, { "color": "red", "value": 85 }] } } }
    },
    {
      "id": 11, "title": "Memory Usage", "type": "timeseries",
      "gridPos": { "x": 8, "y": 14, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "(1 - node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes) * 100", "legendFormat": "Used %" }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "custom": { "fillOpacity": 15 } } }
    },
    {
      "id": 12, "title": "Disk Usage", "type": "gauge",
      "gridPos": { "x": 16, "y": 14, "w": 4, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "(1 - node_filesystem_avail_bytes{mountpoint=\"/\",fstype!~\"tmpfs|overlay\"} / node_filesystem_size_bytes{mountpoint=\"/\",fstype!~\"tmpfs|overlay\"}) * 100" }],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 70 }, { "color": "red", "value": 85 }] } } }
    },
    {
      "id": 13, "title": "Network I/O", "type": "timeseries",
      "gridPos": { "x": 20, "y": 14, "w": 4, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "rate(node_network_receive_bytes_total{device!~\"lo|veth.*|docker.*|br-.*\"}[5m])", "legendFormat": "RX" },
        { "expr": "rate(node_network_transmit_bytes_total{device!~\"lo|veth.*|docker.*|br-.*\"}[5m])", "legendFormat": "TX" }
      ],
      "fieldConfig": { "defaults": { "unit": "Bps", "custom": { "fillOpacity": 10 } } }
    },

    { "id": 300, "title": "PostgreSQL", "type": "row", "gridPos": { "x": 0, "y": 21, "w": 24, "h": 1 } },
    {
      "id": 14, "title": "PG Connections", "type": "timeseries",
      "gridPos": { "x": 0, "y": 22, "w": 6, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(pg_stat_activity_count) by (state)", "legendFormat": "{{state}}" }],
      "fieldConfig": { "defaults": { "custom": { "fillOpacity": 15 } } }
    },
    {
      "id": 15, "title": "Transactions/sec", "type": "timeseries",
      "gridPos": { "x": 6, "y": 22, "w": 6, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(rate(pg_stat_database_xact_commit[5m]))", "legendFormat": "commits/s" },
        { "expr": "sum(rate(pg_stat_database_xact_rollback[5m]))", "legendFormat": "rollbacks/s" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "fillOpacity": 10 } } }
    },
    {
      "id": 16, "title": "PG Cache Hit Ratio", "type": "gauge",
      "gridPos": { "x": 12, "y": 22, "w": 4, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(pg_stat_database_blks_hit) / (sum(pg_stat_database_blks_hit) + sum(pg_stat_database_blks_read)) * 100" }],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 90 }, { "color": "green", "value": 99 }] } } }
    },
    {
      "id": 17, "title": "Database Size", "type": "stat",
      "gridPos": { "x": 16, "y": 22, "w": 4, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(pg_database_size_bytes)" }],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "id": 18, "title": "Deadlocks", "type": "timeseries",
      "gridPos": { "x": 20, "y": 22, "w": 4, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "rate(pg_stat_database_deadlocks[5m])", "legendFormat": "deadlocks" },
        { "expr": "rate(pg_stat_database_conflicts[5m])", "legendFormat": "conflicts" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },

    { "id": 400, "title": "Redis", "type": "row", "gridPos": { "x": 0, "y": 29, "w": 24, "h": 1 } },
    {
      "id": 19, "title": "Redis Memory", "type": "timeseries",
      "gridPos": { "x": 0, "y": 30, "w": 6, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "redis_memory_used_bytes", "legendFormat": "Used" }],
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "fillOpacity": 10 } } }
    },
    {
      "id": 20, "title": "Redis Ops/sec", "type": "timeseries",
      "gridPos": { "x": 6, "y": 30, "w": 6, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "rate(redis_commands_processed_total[5m])", "legendFormat": "cmds/s" }],
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "fillOpacity": 15 } } }
    },
    {
      "id": 21, "title": "Redis Clients", "type": "stat",
      "gridPos": { "x": 12, "y": 30, "w": 4, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "redis_connected_clients" }],
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 100 }, { "color": "red", "value": 200 }] } } }
    },
    {
      "id": 22, "title": "Redis Hit Rate", "type": "gauge",
      "gridPos": { "x": 16, "y": 30, "w": 4, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "redis_keyspace_hits_total / (redis_keyspace_hits_total + redis_keyspace_misses_total) * 100" }],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 70 }, { "color": "green", "value": 90 }] } } }
    },
    {
      "id": 23, "title": "Redis Keys", "type": "stat",
      "gridPos": { "x": 20, "y": 30, "w": 4, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(redis_db_keys)" }],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },

    { "id": 500, "title": "Nginx", "type": "row", "gridPos": { "x": 0, "y": 37, "w": 24, "h": 1 } },
    {
      "id": 24, "title": "Nginx Connections", "type": "timeseries",
      "gridPos": { "x": 0, "y": 38, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "nginx_connections_active", "legendFormat": "active" },
        { "expr": "nginx_connections_reading", "legendFormat": "reading" },
        { "expr": "nginx_connections_writing", "legendFormat": "writing" },
        { "expr": "nginx_connections_waiting", "legendFormat": "waiting" }
      ],
      "fieldConfig": { "defaults": { "custom": { "fillOpacity": 10 } } }
    },
    {
      "id": 25, "title": "Nginx Req/sec", "type": "timeseries",
      "gridPos": { "x": 8, "y": 38, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "rate(nginx_connections_accepted[5m])", "legendFormat": "accepted/s" },
        { "expr": "rate(nginx_connections_handled[5m])", "legendFormat": "handled/s" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "fillOpacity": 10 } } }
    },
    {
      "id": 26, "title": "Nginx Status", "type": "stat",
      "gridPos": { "x": 16, "y": 38, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "nginx_up" }]
    },

    { "id": 600, "title": "SERVIX Business", "type": "row", "gridPos": { "x": 0, "y": 45, "w": 24, "h": 1 } },
    {
      "id": 27, "title": "Daily Revenue (SAR)", "type": "stat",
      "gridPos": { "x": 0, "y": 46, "w": 5, "h": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "servix_daily_revenue_sar" }]
    },
    {
      "id": 28, "title": "Bookings/Hour", "type": "stat",
      "gridPos": { "x": 5, "y": 46, "w": 5, "h": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "servix_bookings_per_hour" }]
    },
    {
      "id": 29, "title": "Active Subscriptions", "type": "stat",
      "gridPos": { "x": 10, "y": 46, "w": 5, "h": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(servix_active_subscriptions) by (plan)", "legendFormat": "{{plan}}" }]
    },
    {
      "id": 30, "title": "Active Tenants", "type": "stat",
      "gridPos": { "x": 15, "y": 46, "w": 4, "h": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "servix_active_tenants_total" }]
    },
    {
      "id": 31, "title": "Payment Success", "type": "gauge",
      "gridPos": { "x": 19, "y": 46, "w": 5, "h": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "servix_payment_success_rate * 100" }],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 90 }, { "color": "green", "value": 95 }] } } }
    }
  ]
}
