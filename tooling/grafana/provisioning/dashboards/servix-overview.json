{
  "dashboard": {
    "id": null,
    "uid": "servix-overview",
    "title": "SERVIX — System Overview",
    "tags": ["servix", "production"],
    "timezone": "browser",
    "schemaVersion": 39,
    "refresh": "30s",
    "time": { "from": "now-1h", "to": "now" },
    "panels": [
      {
        "id": 1,
        "title": "HTTP Request Rate",
        "type": "timeseries",
        "gridPos": { "x": 0, "y": 0, "w": 8, "h": 8 },
        "targets": [
          {
            "expr": "rate(http_requests_total[5m])",
            "legendFormat": "{{method}} {{route}} {{status_code}}"
          }
        ]
      },
      {
        "id": 2,
        "title": "HTTP Latency (p95)",
        "type": "timeseries",
        "gridPos": { "x": 8, "y": 0, "w": 8, "h": 8 },
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket[5m]))",
            "legendFormat": "p95"
          },
          {
            "expr": "histogram_quantile(0.50, rate(http_request_duration_seconds_bucket[5m]))",
            "legendFormat": "p50"
          }
        ]
      },
      {
        "id": 3,
        "title": "Error Rate (5xx)",
        "type": "stat",
        "gridPos": { "x": 16, "y": 0, "w": 8, "h": 4 },
        "targets": [
          {
            "expr": "sum(rate(http_requests_total{status_code=~\"5..\"}[5m])) / sum(rate(http_requests_total[5m])) * 100",
            "legendFormat": "Error %"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "steps": [
                { "color": "green", "value": 0 },
                { "color": "yellow", "value": 1 },
                { "color": "red", "value": 5 }
              ]
            },
            "unit": "percent"
          }
        }
      },
      {
        "id": 4,
        "title": "Active Tenants (Cached)",
        "type": "stat",
        "gridPos": { "x": 16, "y": 4, "w": 8, "h": 4 },
        "targets": [
          {
            "expr": "servix_cached_tenants_total",
            "legendFormat": "Tenants in cache"
          }
        ]
      },
      {
        "id": 5,
        "title": "Node.js Memory Usage",
        "type": "timeseries",
        "gridPos": { "x": 0, "y": 8, "w": 8, "h": 8 },
        "targets": [
          {
            "expr": "process_resident_memory_bytes / 1024 / 1024",
            "legendFormat": "RSS (MB)"
          },
          {
            "expr": "nodejs_heap_size_used_bytes / 1024 / 1024",
            "legendFormat": "Heap Used (MB)"
          }
        ]
      },
      {
        "id": 6,
        "title": "Event Loop Lag",
        "type": "timeseries",
        "gridPos": { "x": 8, "y": 8, "w": 8, "h": 8 },
        "targets": [
          {
            "expr": "nodejs_eventloop_lag_seconds",
            "legendFormat": "Event Loop Lag (s)"
          }
        ]
      },
      {
        "id": 7,
        "title": "PostgreSQL Active Connections",
        "type": "timeseries",
        "gridPos": { "x": 16, "y": 8, "w": 8, "h": 8 },
        "targets": [
          {
            "expr": "pg_stat_activity_count",
            "legendFormat": "{{state}}"
          }
        ]
      },
      {
        "id": 8,
        "title": "BullMQ Queue Depth",
        "type": "timeseries",
        "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
        "targets": [
          {
            "expr": "servix_bullmq_waiting_total",
            "legendFormat": "Waiting"
          },
          {
            "expr": "servix_bullmq_active_total",
            "legendFormat": "Active"
          },
          {
            "expr": "servix_bullmq_failed_total",
            "legendFormat": "Failed (DLQ)"
          }
        ]
      },
      {
        "id": 9,
        "title": "Cache Hit Ratio",
        "type": "gauge",
        "gridPos": { "x": 12, "y": 16, "w": 6, "h": 8 },
        "targets": [
          {
            "expr": "servix_cache_hits_total / (servix_cache_hits_total + servix_cache_misses_total) * 100",
            "legendFormat": "Hit %"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "min": 0,
            "max": 100,
            "unit": "percent",
            "thresholds": {
              "steps": [
                { "color": "red", "value": 0 },
                { "color": "yellow", "value": 70 },
                { "color": "green", "value": 90 }
              ]
            }
          }
        }
      },
      {
        "id": 10,
        "title": "Database Query Duration (p95)",
        "type": "timeseries",
        "gridPos": { "x": 18, "y": 16, "w": 6, "h": 8 },
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(servix_db_query_duration_seconds_bucket[5m]))",
            "legendFormat": "p95 Query Time"
          }
        ]
      }
    ]
  },
  "overwrite": true
}
