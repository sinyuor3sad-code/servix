{
  "id": null,
  "uid": "servix-postgres",
  "title": "SERVIX — PostgreSQL",
  "tags": ["servix", "database", "postgres"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1, "title": "Postgres up", "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "pg_up" }],
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }, "mappings": [{ "type": "value", "options": { "0": { "text": "DOWN" }, "1": { "text": "UP" } } }] } }
    },
    {
      "id": 2, "title": "Active connections", "type": "stat",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(pg_stat_activity_count)" }],
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 50 }, { "color": "red", "value": 80 }] } } }
    },
    {
      "id": 3, "title": "DB size (GB)", "type": "stat",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(pg_database_size_bytes) / 1024 / 1024 / 1024" }],
      "fieldConfig": { "defaults": { "unit": "decgbytes" } }
    },
    {
      "id": 4, "title": "Cache hit ratio", "type": "gauge",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "sum(rate(pg_stat_database_blks_hit[5m])) / (sum(rate(pg_stat_database_blks_hit[5m])) + sum(rate(pg_stat_database_blks_read[5m])))"
      }],
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1, "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 0.95 }, { "color": "green", "value": 0.99 }] } } }
    },
    {
      "id": 5, "title": "Replication lag (s)", "type": "stat",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "max(pg_replication_lag)" }],
      "fieldConfig": { "defaults": { "unit": "s", "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 10 }, { "color": "red", "value": 60 }] } } }
    },
    {
      "id": 6, "title": "Connections by state", "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum by (state) (pg_stat_activity_count)", "legendFormat": "{{state}}" }],
      "fieldConfig": { "defaults": { "custom": { "fillOpacity": 20, "stacking": { "mode": "normal" } } } }
    },
    {
      "id": 7, "title": "Tx/sec (commits vs rollbacks)", "type": "timeseries",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(rate(pg_stat_database_xact_commit[5m]))", "legendFormat": "commits" },
        { "expr": "sum(rate(pg_stat_database_xact_rollback[5m]))", "legendFormat": "rollbacks" }
      ]
    },
    {
      "id": 8, "title": "Slow query p95 (from API)", "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "histogram_quantile(0.95, sum by (operation, le) (rate(servix_db_query_duration_seconds_bucket[5m])))",
        "legendFormat": "{{operation}}"
      }],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 9, "title": "Deadlocks / temp files / conflicts", "type": "timeseries",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "rate(pg_stat_database_deadlocks[5m])", "legendFormat": "deadlocks" },
        { "expr": "rate(pg_stat_database_temp_files[5m])", "legendFormat": "temp files" },
        { "expr": "rate(pg_stat_database_conflicts[5m])", "legendFormat": "conflicts" }
      ]
    }
  ]
}
