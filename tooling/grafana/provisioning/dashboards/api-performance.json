{
  "id": null,
  "uid": "servix-api-performance",
  "title": "SERVIX — API Performance",
  "tags": ["servix", "api", "performance"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "route",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(http_requests_total, route)",
        "refresh": 2,
        "includeAll": true,
        "allValue": ".*",
        "multi": true
      },
      {
        "name": "method",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(http_requests_total, method)",
        "refresh": 2,
        "includeAll": true,
        "allValue": ".*",
        "multi": true
      }
    ]
  },
  "panels": [
    {
      "id": 1, "title": "Requests per second by route", "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "topk(10, sum by (route) (rate(http_requests_total{route=~\"$route\", method=~\"$method\"}[5m])))",
        "legendFormat": "{{route}}"
      }],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "fillOpacity": 10 } } }
    },
    {
      "id": 2, "title": "Latency heatmap (p50/p95/p99)", "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{route=~\"$route\"}[5m])) by (le))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{route=~\"$route\"}[5m])) by (le))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{route=~\"$route\"}[5m])) by (le))", "legendFormat": "p99" }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "fillOpacity": 10 } } }
    },
    {
      "id": 3, "title": "Slowest routes (p95)", "type": "table",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "topk(15, histogram_quantile(0.95, sum by (route, le) (rate(http_request_duration_seconds_bucket[5m]))))",
        "instant": true,
        "format": "table"
      }],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 4, "title": "5xx error rate by route", "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "topk(10, sum by (route) (rate(http_requests_total{status_code=~\"5..\", route=~\"$route\"}[5m])))",
        "legendFormat": "{{route}}"
      }],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "fillOpacity": 20 } } }
    },
    {
      "id": 5, "title": "Apdex (latency ≤ 300ms satisfactory, ≤ 1.2s tolerable)", "type": "stat",
      "gridPos": { "x": 0, "y": 16, "w": 6, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "(sum(rate(http_request_duration_seconds_bucket{le=\"0.3\"}[5m])) + sum(rate(http_request_duration_seconds_bucket{le=\"1.2\"}[5m]))) / 2 / sum(rate(http_request_duration_seconds_count[5m]))"
      }],
      "fieldConfig": { "defaults": { "unit": "none", "min": 0, "max": 1, "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 0.85 }, { "color": "green", "value": 0.95 }] } } }
    },
    {
      "id": 6, "title": "Event loop lag (nodejs)", "type": "timeseries",
      "gridPos": { "x": 6, "y": 16, "w": 9, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "nodejs_eventloop_lag_seconds",
        "legendFormat": "{{instance}}"
      }],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 7, "title": "Heap used (MB)", "type": "timeseries",
      "gridPos": { "x": 15, "y": 16, "w": 9, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "process_resident_memory_bytes / 1024 / 1024",
        "legendFormat": "{{instance}}"
      }],
      "fieldConfig": { "defaults": { "unit": "decmbytes" } }
    }
  ]
}
