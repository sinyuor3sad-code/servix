{
  "name": "servix",
  "version": "0.1.0",
  "private": true,
  "description": "SERVIX - Ultimate Multi-Service Booking Platform",
  "author": "SERVIX Team",
  "license": "UNLICENSED",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "db:generate": "turbo run db:generate",
    "db:migrate": "turbo run db:migrate",
    "db:seed": "turbo run db:seed",
    "db:studio": "turbo run db:studio",
    "clean": "turbo run clean && rimraf node_modules .turbo",
    "docker:up": "docker compose -f tooling/docker/docker-compose.yml up -d",
    "docker:down": "docker compose -f tooling/docker/docker-compose.yml down",
    "docker:prod": "docker compose -f tooling/docker/docker-compose.prod.yml up -d --build",
    "docker:prod:down": "docker compose -f tooling/docker/docker-compose.prod.yml down",
    "create-tenant": "ts-node tooling/scripts/create-tenant.ts",
    "changelog": "conventional-changelog -p angular -i CHANGELOG.md -s"
  },
  "devDependencies": {
    "conventional-changelog-cli": "^5.0.0",
    "pdf-parse": "^2.4.5",
    "rimraf": "^6.0.0",
    "turbo": "^2.9.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@prisma/client",
      "@prisma/engines",
      "@swc/core",
      "prisma",
      "sharp"
    ],
    "overrides": {
      "protobufjs": ">=7.5.5",
      "defu": ">=6.1.5",
      "picomatch": ">=4.0.4",
      "lodash": ">=4.18.1",
      "path-to-regexp": ">=8.4.0",
      "effect": ">=3.20.0"
    }
  }
}