# ══════════════════════════════
# SERVIX — Environment Variables
# ══════════════════════════════

# ── General ──
NODE_ENV=development

# ── PostgreSQL ──
POSTGRES_USER=servix
POSTGRES_PASSWORD=servix_secret
POSTGRES_DB=servix_platform
POSTGRES_PORT=5432

# ── Redis ──
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=servix_redis

# ── MinIO ──
MINIO_ROOT_USER=servix_minio
MINIO_ROOT_PASSWORD=servix_minio_secret
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# ── API ──
PORT=4000
PLATFORM_DATABASE_URL=postgresql://servix:servix_secret@localhost:5432/servix_platform
JWT_ACCESS_SECRET=change-me-in-production-access
JWT_REFRESH_SECRET=change-me-in-production-refresh
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,https://app.servi-x.com,https://booking.servi-x.com,https://admin.servi-x.com,https://servi-x.com

# ── Rate Limiting ──
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ── Storage ──
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=servix_minio
S3_SECRET_KEY=servix_minio_secret
S3_BUCKET=servix-uploads

# ── Email (placeholder) ──
MAIL_API_KEY=
MAIL_FROM=noreply@servi-x.com

# ── SMS (placeholder) ──
SMS_API_KEY=
SMS_SENDER_ID=SERVIX

# ── WhatsApp ──
# NOTE: WhatsApp credentials are stored PER-TENANT in the tenant database settings table.
# Do NOT configure WhatsApp credentials here. Each salon connects their own WhatsApp Business account.
# The verify token below is used by Meta to validate the webhook endpoint during setup.
WHATSAPP_WEBHOOK_VERIFY_TOKEN=servix-webhook-verify-2026

# ── AI (Gemini) ──
# Free API key from https://aistudio.google.com/apikey
# Model: gemini-2.0-flash (free tier: 15 req/min)
GEMINI_API_KEY=

# ── Evolution API (WhatsApp gateway for n8n) ──
# Shared master API key. Each salon also gets its own per-instance tokens.
# Generate with: openssl rand -hex 32
EVOLUTION_API_KEY=change-me-in-production
# Internal URL (inside docker network). Override for local dev if needed.
EVOLUTION_API_URL=http://evolution-api:8080

# ── n8n (workflow automation) ──
N8N_BASIC_AUTH_USER=servix_admin
N8N_BASIC_AUTH_PASSWORD=change-me-in-production
N8N_ENCRYPTION_KEY=change-me-32-chars-for-production

# ── Dashboard (NEXT_PUBLIC_*) ──
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_WS_URL=http://localhost:4000
NEXT_PUBLIC_DASHBOARD_URL=http://localhost:3000

# ── Production URLs ──
# NEXT_PUBLIC_API_URL=https://api.servi-x.com/api/v1
# NEXT_PUBLIC_WS_URL=https://api.servi-x.com
# NEXT_PUBLIC_DASHBOARD_URL=https://app.servi-x.com
# CORS_ORIGINS=https://app.servi-x.com,https://booking.servi-x.com,https://admin.servi-x.com,https://servi-x.com

# ── ZATCA E-Invoicing ──
# Environment: developer-portal (testing) | simulation (UAT) | core (production)
ZATCA_ENV=developer-portal
# Override full URL if needed:
# ZATCA_API_URL=https://gw-fatoora.zatca.gov.sa/e-invoicing/developer-portal
# Encryption key for private key storage (AES-256) — MUST change in production!
ENCRYPTION_KEY=change-me-32-chars-for-production

# ── OTP Generation ──
# Get OTP from: https://fatoora.zatca.gov.sa → Simulation Portal → Onboard New Device
# OTP is valid for 1 hour only

# ── Deploy ──
REGISTRY_URL=
SERVER_HOST=
API_URL=http://localhost:4000/api/v1
