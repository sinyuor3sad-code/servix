# ══════════════════════════════
# SERVIX — Environment Variables
# ══════════════════════════════

# ── General ──
NODE_ENV=development

# ── PostgreSQL ──
POSTGRES_USER=servix
POSTGRES_PASSWORD=servix_secret
POSTGRES_DB=servix_platform
POSTGRES_PORT=5432

# ── Redis ──
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=servix_redis

# ── MinIO ──
MINIO_ROOT_USER=servix_minio
MINIO_ROOT_PASSWORD=servix_minio_secret
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# ── API ──
PORT=4000
PLATFORM_DATABASE_URL=postgresql://servix:servix_secret@localhost:5432/servix_platform
JWT_ACCESS_SECRET=change-me-in-production-access
JWT_REFRESH_SECRET=change-me-in-production-refresh
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002

# ── Rate Limiting ──
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ── Storage ──
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=servix_minio
S3_SECRET_KEY=servix_minio_secret
S3_BUCKET=servix-uploads

# ── Email (placeholder) ──
MAIL_API_KEY=
MAIL_FROM=noreply@servix.sa

# ── SMS (placeholder) ──
SMS_API_KEY=
SMS_SENDER_ID=SERVIX

# ── WhatsApp (placeholder) ──
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# ── Dashboard (NEXT_PUBLIC_*) ──
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_WS_URL=http://localhost:4000

# ── Deploy ──
REGISTRY_URL=
SERVER_HOST=
API_URL=http://localhost:4000/api/v1
