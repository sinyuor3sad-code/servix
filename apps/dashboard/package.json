{
  "name": "@servix/dashboard",
  "version": "0.1.0",
  "private": true,
  "description": "SERVIX Dashboard — Salon Management Panel",
  "scripts": {
    "dev": "next dev --port 3000",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:pact": "vitest run --config vitest.pact.config.ts",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:debug": "playwright test --debug",
    "e2e:update": "playwright test --update-snapshots",
    "e2e:ci": "CI=1 PLAYWRIGHT_WEB_SERVER=1 playwright test",
    "e2e:install": "playwright install --with-deps chromium webkit",
    "e2e:report": "playwright show-report",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "lighthouse": "lhci autorun",
    "clean": "rimraf .next .turbo"
  },
  "dependencies": {
    "@hookform/resolvers": "^4.0.0",
    "@radix-ui/react-switch": "^1.2.6",
    "@tanstack/react-query": "^5.0.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "lucide-react": "^0.469.0",
    "motion": "^12.0.0",
    "next": "^15.5.15",
    "next-intl": "^4.0.0",
    "next-themes": "^0.4.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.54.0",
    "recharts": "^2.15.0",
    "socket.io-client": "^4.8.3",
    "sonner": "^2.0.0",
    "tailwind-merge": "^3.0.0",
    "zod": "^3.24.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.9.0",
    "@lhci/cli": "^0.14.0",
    "@pact-foundation/pact": "^13.0.0",
    "@playwright/test": "^1.59.1",
    "@storybook/addon-a11y": "^8.0.0",
    "@storybook/addon-essentials": "^8.0.0",
    "@storybook/addon-interactions": "^8.0.0",
    "@storybook/blocks": "^8.0.0",
    "@storybook/react-vite": "^8.0.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^4.1.3",
    "eslint": "^10.2.1",
    "eslint-config-next": "^15.5.13",
    "jsdom": "^29.0.2",
    "postcss": "^8.5.0",
    "rimraf": "^6.0.0",
    "storybook": "^8.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.3"
  }
}
