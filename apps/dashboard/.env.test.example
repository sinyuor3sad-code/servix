# ─────────────────────────────────────────────
# Playwright E2E configuration
#
# Copy to apps/dashboard/.env.test and fill in the values you want to
# override. Defaults are wired to the dev seed data (servix@dev.local).
# ─────────────────────────────────────────────

# URL of the dashboard under test.
PLAYWRIGHT_BASE_URL=http://localhost:3000

# Owner-role credentials used by global-setup.ts to capture auth state.
TEST_EMAIL=servix@dev.local
TEST_PASSWORD=adsf1324

# Cashier-role credentials (used when a test needs reduced privileges).
TEST_CASHIER_EMAIL=cashier@dev.local
TEST_CASHIER_PASSWORD=adsf1324

# When set, Playwright will boot the Next dev server and wait on
# PLAYWRIGHT_BASE_URL before running the suite. Leave empty when running
# locally with a dev server already started.
PLAYWRIGHT_WEB_SERVER=
