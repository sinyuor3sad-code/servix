NODE_ENV=development
PORT=4000

# Database
PLATFORM_DATABASE_URL=postgresql://servix:servix_password@localhost:5432/servix_platform

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_ACCESS_SECRET=your-access-secret-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# Storage (MinIO for local dev)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=servix_minio
S3_SECRET_KEY=servix_minio_secret
S3_BUCKET=servix-uploads

# Email (placeholder)
MAIL_API_KEY=
MAIL_FROM=noreply@servix.sa

# SMS (placeholder)
SMS_API_KEY=
SMS_SENDER_ID=SERVIX

# WhatsApp (placeholder)
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
